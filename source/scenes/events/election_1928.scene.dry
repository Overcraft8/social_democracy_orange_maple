title: Legislative Election
new-page: true
tags: event
priority: -1
view-if: (year = next_parl_election_year and month >= next_parl_election_month) or (year > next_parl_election_year)
on-departure: month_actions += 1; in_election = 0; next_parl_election_year = next_parl_election_year + 4; n_elections += 1; next_election_time = time + 48; papen_premier_timer = 4;
set-jump: post_election_1928
face-image: img/Rothe_Wahlen_1903.jpg

# TODO: should there be an image?

# the low priority means that this event is only seen after all other events are resolved for the month.

= Elections, [+ month : month +] [+ year +]

The Assembly elections are to be held now.

- @election_algorithm: May we do our best...


@post_election_1928
on-arrival: {!
// set old results
// election threshold constitutional reform
// banning parties
var new_party_sum = 0;
for (var party of Q.parties) {
    Q['old_' + party + '_r'] = Q[party + '_r'];
    if (Q.constitutional_reform > 0) {
        if (Q[party + '_votes'] < Q.electoral_threshold || (Q.electoral_threshold > 1 && party == 'other') || Q[party + '_banned']) {
            Q[party + '_r'] = 0;
        } else {
            Q[party + '_r'] = Q[party + '_votes'];
        }
        new_party_sum += Q[party + '_r'];
    } else {
        Q[party + '_r'] = Q[party + '_votes'];
    }
    // if we use decimals, then we might want to truncate the numbers
    if (Q.use_decimals) {
        Q[party + '_r_disp'] = Q[party+'_r'];
    }  else {
            Q[party + '_r_disp'] = Q[party+'_r'];
    }
    Q['change_' + party + '_r'] = Q[party + '_r'] - Q['old_' + party + '_r'];
    var sign = Q['change_' + party + '_r'] > 0 ? '+'  : '';
    Q['str_change_' + party] = sign + Q['change_' + party + '_r'].toFixed(1);
}
// calculate new party sum if electoral reform
if (Q.electoral_threshold && Q.electoral_threshold > 0) {
    for (var party of Q.parties) {
        if (Q[party + '_r'] > 0) {
            if (Q.use_decimals) {
                Q[party + '_r'] = Math.round(Q[party + '_r']*1000/new_party_sum)/10;
            } else {
                Q[party + '_r'] = Math.round(Q[party + '_r']*100/new_party_sum);
            }
        }
        if (Q.use_decimals) {
            Q[party + '_r_disp'] = Q[party+'_r'];
        } else {
            Q[party + '_r_disp'] = Q[party+'_r'];
        }
        Q['change_' + party + '_r'] = Q[party + '_r'] - Q['old_' + party + '_r'];
        var sign = Q['change_' + party + '_r'] > 0 ? '+'  : '';
        Q['str_change_' + party] = sign + Q['change_' + party + '_r'].toFixed(1);
    }
}

// get change arrows and signs


// The largest party can only be the FLP, LPS, CPS, or SCP.
Q.largest_party = 'FLP';

if (Q.lps_r >= Q.flp_r && Q.lps_r >= Q.cps_r && Q.lps_r >= Q.scp_r) {
    Q.largest_party = 'LPS';
}
if (Q.cps_r >= Q.flp_r && Q.cps_r >= Q.lps_r && Q.cps_r >= Q.scp_r) {
    Q.largest_party = 'CP';
}
if (Q.scp_r >= Q.flp_r && Q.scp_r >= Q.lps_r && Q.scp_r >= Q.cps_r) {
    Q.largest_party = 'CP';
}

// coalitions
Q.weimar_coalition = Q.flp_r + Q.lps_r + Q.pps_r;
Q.grand_coalition = Q.flp_r + Q.lps_r + Q.pps_r + Q.cps_r;
Q.bourgeois_coalition = Q.lps_r + Q.pps_r + Q.cps_r + Q.other_r;
Q.center_right_coalition = Q.pps_r + Q.lps_r + Q.cps_r + Q.other_r + Q.scp_r;
Q.right_coalition = Q.pps_r + Q.cps_r + Q.other_r + Q.scp_r;
Q.scp_majority = Q.scp_r 
Q.left_coalition = Q.flp_r + Q.cp_r + Q.sapd_r;
// this is an absurd concept lol
Q.popular_front_coalition = Q.flp_r + Q.cp_r + Q.pps_r + Q.lps_r + Q.sapd_r;
Q.anti_democratic_coalition = Q.cp_r + Q.scp_r;
// aka everyone except scp, cp, scp
Q.neo_weimar_coalition = Q.flp_r + Q.lps_r + Q.pps_r + Q.cps_r + Q.other_r;
// Needham + Right-wing parties (only comes into effect if you've alienated PPS too badly)
Q.needham_right_coalition = Q.pps_r + Q.scp_r
// Progressive coalition isn't going to be implemented as a distinct coalition but it's the coalition that lets you pass improved women's rights/gay rights
Q.progressive_coalition = Q.flp_r + Q.cp_r + Q.lps_r + Q.sapd_r;

if (Q.cp_relation >= 30) {
    Q.weimar_coalition += Q.sapd_r;
}

Q.leverage = Q.flp_r;

Q.grand_coalition_failed = 0;
// Reset government and ministers... Based on Brüning's 1930 govt
Q.coalition_dissent = 0;
Q.cp_coalition_dissent = 0;
Q.flp_in_government = 0;
Q.in_weimar_coalition = 0;
Q.in_grand_coalition = 0;
Q.in_left_front = 0;
Q.in_popular_front = 0;
Q.in_emergency_government = 0;
Q.in_minority_government = 0;
Q.in_unity_government = 0;
Q.flp_toleration = 0;
Q.flp_caretaker = 0;
// New Ministries
Q.cooperatives_minister_party = 'PPS';
Q.education_minister_party = 'PPS';
Q.Mineral_resources_minister_party = 'PPS';
Q.Municipal_affairs_minister_party = 'PPS';
Q.transportation_minister_party = 'PPS';
Q.telephones_telegraphs_minister_party = 'PPS';
// Old Ministries
Q.foreign_minister_party = 'CPS';
Q.interior_minister_party = 'PPS';
Q.justice_minister_party = 'I';
Q.labour_minister_party = 'PPS';
Q.rcmp_minister_party = 'I';
Q.economic_minister_party = Q.lps_name;
Q.finance_minister_party = 'CPS';
Q.agriculture_minister_party = 'PPS';

// reset CP goals
Q.cp_goals_seen = 0;
Q.cp_ultimatum_seen = 0;
Q.welfare_goal = 0;
Q.agriculture_goal = 0;
Q.economy_goal = 0;
Q.finance_goal = 0;
Q.labour_goal = 0;
Q.foreign_goal = 0;
Q.interior_goal = 0;
Q.rcmp_goal = 0;

Q.welfare_goal_completed = 0;
Q.agriculture_goal_completed = 0;
Q.economy_goal_completed = 0;
Q.finance_goal_completed = 0;
Q.labour_goal_completed = 0;
Q.foreign_goal_completed = 0;
Q.interior_goal_completed = 0;
Q.rcmp_goal_completed = 0;

Q.strike_term_seen = 0;

Q.pps_r = Q.pps_r;

// understanding the enemy
if (Q.scp_r >= 15) {
    Q.understanding_enemy_timer = 2;
}

var election_result = {'date': new Date(Q.year, Q.month - 1)};
for (var party of Q.parties) {
    election_result[party] = Q[party + '_r'];
}
Q.election_records.push(election_result);
!}
on-departure: scp_urgency = 1 if (scp_urgency == 0 and scp_r >= 15)
on-display: {!
data = [
    {
        "id": "cp",
        "legend": "CP",
        "name": "CP",
        "seats": Math.round(Q.cp_r * 0.6),
    }
];
if (Q.sapd_formed && Q.sapd_r) {
    data.push({
            "id": "sapd",
            "legend": "SAPD",
            "name": "SAPD",
            "seats": Math.round(Q.sapd_r * 0.6),
            });
}
data = data.concat([
    {
        "id": "flp",
        "legend": "FLP",
        "name": "FLP",
        "seats": Math.round(Q.flp_r * 0.6),
    },
    {
        "id": "lps",
        "legend": "LPS",
        "name": "LPS",
        "seats": Math.round(Q.lps_r * 0.6),
    },
    {
        "id": "pps",
        "legend": "PPS",
        "name": "PPS",
        "seats": Math.round(Q.pps_r * 0.6),
    },
    {
        "id": "cps",
        "legend": "CPS",
        "name": "CPS",
        "seats": Math.round(Q.cps_r * 0.6),
    },
    {
        "id": "other",
        "legend": "Other",
        "name": "Other",
        "seats": Math.round(Q.other_r * 0.6),
    },
    {
        "id": "scp",
        "legend": "SCP",
        "name": "SCP",
        "seats": Math.round(Q.scp_r * 0.6),
    },
]);

if (window && d3) {
    var width = 500; 
    var height = 500;
    var screenWidth = document.getElementById('content').offsetWidth;
    if (screenWidth < width - 50) {
        width = screenWidth - 50; 
        height = width;
        document.getElementById("assembly").style.height = screenWidth/2 + "px";
    } 

    var parliament = d3.parliament();
    parliament.width(width).height(height).innerRadiusCoef(0.4);
    parliament.enter.fromCenter(true).smallToBig(true);
    parliament.exit.toCenter(false).bigToSmall(true);
    d3.select("#assembly").datum(data).call(parliament);
}
!}
go-to: coalition_menu

= Election results

{!<svg id="assembly" style="width: 500px; height: 250px;"> </svg>!}

{!<table>!} 
{!<tr><td>Party</td><td>Vote share</td><td>% Change</td></tr>!}

{!<tr><td><div class="box" style='background-color:#D26E28; outline: 2px; outline-style: solid;'> </div> !} **FLP:** {!</td><td>!} **[+ flp_r +]%** {!</td><td>!} **[+ str_change_flp +]** {!</td></tr>!}

[? if sapd_formed : {!<tr><td><div class="box" style='background-color:#C40000'> </div> !}SAPD: {!</td><td>!} [+ sapd_r +]% {!</td><td>!} [+ str_change_sapd +] {!</td></tr>!} ?]

{!<tr><td><div class="box" style='background-color:#920c0c'> </div> !} CP: {!</td><td>!} [+ cp_r +]% {!</td><td>!} [+ str_change_cp +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#BE0028'> </div> !} [+ lps_name +]: {!</td><td>!} [+ lps_r +]% {!</td><td>!} [+ str_change_lps +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#E7DB73'> </div> !} PPS: {!</td><td>!} [+ pps_r +]% {!</td><td>!} [+ str_change_pps +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#0055A5'> </div> !} CPS: {!</td><td>!} [+ cps_r +]% {!</td><td>!} [+ str_change_cps +] {!</td></tr>!}
 
{!<tr><td><div class="box" style='background-color:#a0a0a0'> </div> !} Others: {!</td><td>!} [+ other_r +] % {!</td><td>!} [+ str_change_other +] {!</td></tr>!}

{!<tr><td><div class="box" style='background-color:#50E23D'> </div> !} SCP: {!</td><td>!} [+ scp_r +]% {!</td><td>!} [+ str_change_scp +] {!</td></tr>!}

{!</table>!}

**Potential coalitions:**

Weimar Coalition (FLP + PPS + [+ lps_name +]): [+ weimar_coalition +]%

Grand Coalition (FLP + PPS + [+ lps_name +] + CPS): [+ grand_coalition +]%

Bourgeois Coalition (PPS + [+ lps_name +] + CPS + Others): [+ bourgeois_coalition +]%

Right-wing Coalition (PPS + CPS + Others + SCP): [+ right_coalition +]%

[? if scp_urgency <= 1 and scp_r >= 15 : The rapid rise in SCP votes is extremely worrying. Many had believed that the party was moribund; now, some of us consider it to be the greatest threat to democracy in Saskatchewan. ?]

[? if anti_democratic_coalition >= 50 : Together, the anti-democratic CP, SCP, and SCP have a majority in the Assembly. A stable governing majority will be almost impossible. ?]

There are some potential coalition arrangements.

@coalition_menu

- @flp_majority
- @weimar_coalition
- @grand_coalition
- @new_grand_coalition
- @unity_government
- @scp_majority
- @no_majority
- @woodsworths_dilemma
- @left_coalition
- @popular_front_coalition
- @right_coalition

# TODO: black-brown coalition


@popular_front_coalition
title: A new "Popular Front" coalition?
subtitle: FLP + CP + PPS + [+ lps_name +]  [? if sapd_formed: + SAPD ?]([+ popular_front_coalition +]%)
unavailable-subtitle: FLP + CP + PPS + [+ lps_name +] [? if sapd_formed: + SAPD ?]([+ popular_front_coalition +]%) - [? if ((cp_relation < 65 and cp_party_leader == "Tim Buck") or (cp_relation < 45 and cp_party_leader == "Conciliators")): We do not have good enough relations with the CP. ?][? if (pps_relation < 45 and pps_party_leader == "Joos") or (pps_relation < 65 and pps_party_leader != "Joos" and cp_party_leader != "Conciliators") or (pps_relation < 55 and pps_party_leader != "Joos" and cp_party_leader == "Conciliators"): We do not have good enough relations with the PPS Party. ?][? if communist_coalition < 3 : The Communists are unwilling to compromise at all. ?]
view-if: popular_front_coalition >= 50
choose-if: (((cp_relation >= 65 and cp_party_leader == "Tim Buck") or (cp_relation >= 45 and cp_party_leader == "Conciliators")) and ((pps_relation >= 45 and pps_party_leader == "Joos") or (pps_relation >= 65 and pps_party_leader != "Joos" and cp_party_leader != "Conciliators") or (pps_relation >= 55 and pps_party_leader != "Joos" and cp_party_leader == "Conciliators")) and lps_relation >= 50 and communist_coalition >= 3) or (pps_party_leader == "Joos" and cp_party_leader == "Conciliators" and pps_relation >= 30 and cp_relation >= 30)

Could we really form a coalition that included both the PPS and the Communists? It seems like an absurd concept, but given our good relationships with both sides, it is not an impossibility.

The far-right might attempt a coup, if such a coalition were formed.

- @popular_front_2: Form the Popular Front!
- @great_popular_front: Form the Popular Front!

@popular_front_2
view-if: pps_party_leader != "Joos" or cp_party_leader != "Conciliators"

Somehow, both the Communists and PPS are at the very least willing to entertain negotiations. Of course, CP radicals and PPS conservatives derail the negotiations almost immediately. The CP demands leadership of the coalition for themselves and their chairman Tim Buck, [? if flp_r > cp_r : despite our higher vote share, ?]while the PPS is offended by the prospect of helping Bolsheviks enter government. *Something* must be done to restore balance.

- @popular_front_resources
- @popular_front_democracy
- @popular_front_woodsworth
- @coalition_menu: This is impossible. Try another governing arrangement.

@popular_front_resources
title: Use our resources to smooth things over.
unavailable-subtitle: Required: 4 resources
subtitle: -4 resources
choose-if: resources >= 4
on-arrival: resources -= 4
go-to: popular_front_success

@popular_front_democracy
title: Convince the CP to accept democracy.
subtitle: [? if cp_party_leader == "Conciliators" : The Conciliator leadership of the CP at least claim to support the Popular Front. ?]
unavailable-subtitle: Our relationship with the CP is not high enough.
choose-if: (cp_relation >= 60 and communist_coalition >= 3) or cp_party_leader == "Conciliators"
go-to: popular_front_success

@popular_front_woodsworth
title: Use pressure from Monarch J. S. Woodsworth to force the parties to cooperate.
view-if: monarch == "J. S. Woodsworth"
go-to: popular_front_success

@great_popular_front
view-if: pps_party_leader == "Joos" and cp_party_leader == "Conciliators"
on-arrival: flp_in_government = 1; in_popular_front = 1; premier = "Williams"; premier_party = "FLP"; cp_relation += 10; coup_progress += 2; in_left_front = 0; in_weimar_coalition = 0; in_grand_coalition = 0; coalition_dissent = 0;
achievement: grosse_volksfront
go-to: popular_front_success

Somehow, the coalition is successfully formed! The conciliatory leadership of the PPS Party and CP helped make the negotiations possible. We still need a premier; the only acceptable choice among the parties was George Hara Williams of the FLP, acceptable to the PPS and CP [? if monarch == "George V" : as well as Monarch George V, albeit extremely reluctantly ?].

@popular_front_success
on-arrival: flp_in_government = 1; in_popular_front = 1; premier = "Williams"; premier_party = "FLP"; cp_relation += 10; coup_progress += 2; in_left_front = 0; in_weimar_coalition = 0; in_grand_coalition = 0; coalition_dissent = 0;
go-to: popular_front_no_civil_war
achievement: volksfront

Somehow, surprisingly, the coalition is successfully formed! We still need a premier; the only acceptable choice among the parties was George Hara Williams of the FLP, acceptable to the PPS and CP [? if monarch == "George V" : as well as Monarch George V, albeit extremely reluctantly ?].

@popular_front_no_civil_war
on-arrival: cp_goals_seen = 0; finance_minister_party = "PPS"; interior_minister_party = "PPS"; economic_minister_party = "PPS"; labour_minister_party = "PPS"; foreign_minister_party = "PPS"; agriculture_minister_party = "PPS"; rcmp_minister = "I"; leverage = flp_r + cp_r;
achievement: volksfront

In response to the CP's entrance into the government, the right-wing takes a "wait-and-see" approach for now. They expect that the Popular Front government will be unstable and incompetent, and will collapse of its own accord, discrediting the left and center and eventually enabling the destruction of the Weimar Republic. Our task is to prove them wrong.

The CP has taken an abstentionist position with regards to ministries. They claim to be participating as the "loyal opposition" within the Popular Front government, supporting us from the outside while also running their own propaganda campaigns to turn workers to their side. They seem to expect that the Popular Front would inevitably fail, and that our failure would benefit them.

- @ministries: First, we must select our ministries.


@scp_majority
title: Far-right coalition
subtitle: SCP ([+ scp_majority +]%)
view-if: scp_majority >= 50
go-to: scp_win if (year >= 1932 or scp_r >= 44) and monarch != "J. S. Woodsworth"; far_right_fail if (year < 1932 and scp_r < 44) and monarch != "J. S. Woodsworth"; far_right_woodsworth if monarch == "J. S. Woodsworth"
priority: 2

There are enough votes for the SCPs and the SCP to form a coalition. [+ scp_leader +] has made his participation in government contingent on being appointed premier. It is up to Monarch [+ monarch +] to decide.

@scp_win
on-arrival: premier = scp_leader; premier_party = "SCP"

[? if monarch == "George V" : Monarch George V's camarilla ?][? if monarch == "J. S. Woodsworth" : Monarch J. S. Woodsworth somehow ?] has decided that [+ scp_leader +] must be premier [? if monarch == "George V": , and the aging monarch accepts their recommendations. ?][? if monarch == "J. S. Woodsworth" : because it is what the constitution would stipulate. ?]

The SCPs have won. The establishment is in shock, but there is little they can do about it. The SCPs will now be able to consolidate their power and implement their agenda.

@far_right_fail
on-arrival: premier = "Schleicher"; premier_party = "I"; pro_republic -= 10; next_election_time = time+5; next_parl_election_month = month + 5; next_parl_election_year = year; next_parl_election_year += 1 if next_parl_election_month > 12; next_parl_election_month -= 12 if next_parl_election_month > 12;

The reactionary establishment is still very skeptical of the SCPs, so instead, [+ monarch +] appoints Kurt von Schleicher, a former general, as premier, to try to "tame" the SCPs.

Schleicher's government is deeply unpopular among all parties of the Assembly. Despite his support for a coalition with the SCP, the SCPs want power all to themselves, without Schleicher.

New elections have been set for [+ next_parl_election_month : month +] [+ next_parl_election_year +].

@far_right_woodsworth
on-arrival: coup_progress += 2

Monarch J. S. Woodsworth faces a dilemma. Is it "democratic" to let democracy be destroyed, if the majority of voters have willed it so? Some, even on the left, suggest that the SCPs would not *truly* be as horrific as their platform suggests, and that giving them power would let them discredit themselves in the eyes of the public.

Alternatively, J. S. Woodsworth could use the emergency powers of the presidency. Article 48 has been used by George V to promulgate anti-democratic and anti-worker policies; can Article 48 be used for good as well as evil?

- @new_elections: We will have new elections.
- @scp_win: Let the SCPs form their government.


@left_coalition
title: Is a United Left coalition possible?
subtitle: FLP + CP [? if sapd_formed: + SAPD ?] ([+ left_coalition +]%)
unavailable-subtitle: FLP + CP [? if sapd_formed: + SAPD ?] ([+ left_coalition +]%). [? if cp_relation < 50 : We do not have adequate relations with the CP. ?][? if communist_coalition < 3 : The Communists are too committed to their radical ways to partake in government. ?]
view-if: left_coalition >= 50
choose-if: (cp_relation >= 50 or (cp_party_leader == "Conciliators" and cp_relation >= 40)) and communist_coalition >= 3

There are enough votes for a FLP + CP coalition government, if such a thing were actually possible.

The far-right might attempt a coup, if such a coalition were formed.

- @left_coalition_impossible: This is impossible.
- @left_coalition_possible: This could be possible.

@left_coalition_impossible
go-to: coalition_menu

A far left coalition is impossible.


@left_coalition_possible

The CP is still very reluctant to join a coalition, despite grassroots friendliness between our memberships. The Stalinist leadership is vehemently against such a thing. They demand the appointment of Tim Buck as premier in exchange for a coalition. [? if monarch == "George V" : There is no chance whatsoever that Monarch George V would approve of the appointment of a die-hard communist as premier. ?] Alternatively, if our relations with them are good enough, we could convince them to support the appointment of one of our agrarian or left-leaning members as premier.

- @tim_buck_premier: Appoint Tim Buck as premier.
- @left_coalition_resources
- @left_coalition_relations
- @coalition_menu: Try a different governing arrangement.

@tim_buck_premier
choose-if: monarch == "J. S. Woodsworth" and reformist_strength + neorevisionist_strength < left_strength
unavailable-subtitle: [? if monarch != "J. S. Woodsworth": Monarch [+ monarch +] would never allow such a thing. ?] [? if reformist_strength >= left_strength : Most in the parliamentary party would not support Tim Buck as premier. ?]
on-arrival: premier = "Tim Buck"; premier_party = "CP"; cp_relation = 80; in_left_front = 1; flp_in_government = 1 

With great reluctance, Monarch [+ monarch +] appoints [+ premier +] as premier.

Immediately, [+ premier +] goes to work building a "Soviet Saskatchewan": consolidating as much power as possible in the CP, purging state institutions of anti-communists, and sending street fighters against the "enemies of the people".

In response to [+ premier +] being appointed Premier, the right-wing forces launches almost immediately launch an attempted coup. Troops of the Ku Klux Klan and SCPs FUL enter Berlin and immediately begin clashing with our supporters! Reactionary officers within the RCMP have taken their troops out of the barracks and joined them with the Ku Klux Klan to stop the CP from taking power. We are forced to be on the same side as the CP, whether we want to or not.



@left_coalition_resources
title: Use our resources to smooth things over.
unavailable-subtitle: Required: 3 resources
subtitle: -3 resources
choose-if: resources >= 3
on-arrival: resources -= 3
go-to: left_coalition_success

@left_coalition_relations
title: Convince the CP to accept democracy.
unavailable-subtitle: Our relationships with the CP are not good enough.
choose-if: cp_relation >= 60 or cp_party_leader == "Conciliators"
go-to: left_coalition_success


@left_coalition_success
on-arrival: flp_in_government = 1; in_left_front = 1; premier = "Williams"; premier_party = "FLP"; coup_progress += 3; capital_strike_progress += 2; in_popular_front = 0; in_grand_coalition = 0; in_weimar_coalition = 0; cp_relation += 10
go-to: left_coalition_no_civil_war
achievement: einheitsfront

Somehow, surprisingly, the left coalition is successfully formed, without appointing Tim Buck as premier. The consensus choice for premier, accepted by the FLP, CP, and Monarch [+ monarch +], is George Hara Williams, who belongs to the agrarian faction of the FLP, but was acceptable to the left due to his previous membership in the left-wing anti-war UFLP.

# just raise the coup limit, don't immediately go to civil war

@left_coalition_no_civil_war
on-arrival: cp_goals_seen = 0; foreign_minister_party = "FLP"; interior_minister_party = "FLP"; justice_minister_party = "FLP"; labour_minister_party = "FLP"; rcmp_minister_party = "FLP"; economic_minister_party = "FLP"; finance_minister_party = "FLP"; agriculture_minister_party = "FLP"; rcmp_loyalty -= 0.05

In response to the CP's entrance into the government, the right-wing takes a "wait-and-see" approach for now. They expect that our government will be unstable and incompetent, and will collapse of its own accord, discrediting the left and eventually enabling the destruction of the Weimar Republic. Our task is to prove them wrong.

The CP has taken an abstentionist position with regards to ministries. They claim to be participating as the "loyal opposition" in the worker's government, supporting us from the outside while also running their own propaganda campaigns to turn workers to their side. They seem to expect that we would inevitably fail, and that our failure would benefit them. 

Whatever their reasoning is, the FLP has control over the ministries of government.

@left_coalition_civil_war
on-arrival: rcmp_loyalty += 0.1





@right_coalition
title: Refuse to form a government, so that a right-wing coalition may be formed.
subtitle: PPS + CPS + SCP + Others ([+ right_coalition +]%)
unavailable-subtitle: The SCP is not interested in a coalition with the PPS.
view-if: right_coalition >= 50
choose-if: year < 1929

There are enough votes for a right-wing coalition of the PPS, CPS, SCP, and minor conservative parties. [? if largest_party == "FLP": However, this will be seen as abdicating responsibility for government, as we are the largest party. ?]

- @right_coalition_sure: Yes, we will abdicate our responsibility for government formation, and let a right-wing coalition take power.
- @grand_coalition: Actually, we wish to form a grand coalition after all.

@no_right_coalition
go-to: no_majority

However, the SCP and its leader Hugenberg is refusing to partake in a coalition with the "November criminals" in the PPS Party. Thus, there is no clear path towards a Assembly majority.

@right_coalition_sure
subtitle: This will be extremely unpopular within our party.
on-arrival: pro_republic -= 5; agrarian_dissent += 15; left_dissent += 10; labour_dissent += 25; reformist_dissent += 25; neorevisionist_dissent += 15; pps_relation -= 5; lps_relation -= 5; cps_relation -= 5
go-to: right_coalition_2


@right_coalition_2
unavailable-subtitle: The SCP is not interested in a coalition with the PPS.
view-if: right_coalition >= 50
choose-if: year < 1929
on-arrival: flp_in_government = 0; flp_toleration = 0; premier = "Brüning"; premier_party = "PPS"; foreign_minister_party = "CPS"; interior_minister_party = "SCP"; justice_minister_party = "SCP"; labour_minister_party = "PPS"; rcmp_minister_party = "I"; economic_minister_party = "CPS"; finance_minister_party = "PPS"; agriculture_minister_party = "SCP"; in_right_coalition = 1;

Even though the SCP is very reluctant to participate in such a coalition, they still accede to Monarch George V's wishes. Thus, a majority center-right coalition is formed, with Brüning as premier.



@no_majority
title: There is no clear governing majority.
view-if: weimar_coalition < 50 and (grand_coalition < 50 or grand_coalition_failed == 1) and monarch = "George V" and scp_majority < 50
on-arrival: no_majority_elections += 1
go-to: no_majority_bruning if premier = "Brüning" or premier = "Wirth"; no_majority_papen if premier = "Papen" and no_majority_papen_elections == 0; no_majority_papen_2 if premier == "Papen" and no_majority_papen_elections > 0; no_majority_flp if premier_party = "FLP" or premier == "James Anderson"

# TODO: if there is an anti-democratic coalition majority, you should appoint Papen.

# either new elections, or George V appoints either Brüning, Papen, Schleicher, or Needham.

@no_majority_flp
on-arrival: premier = "Brüning"; premier_party = "PPS"

There is no path to an obviously workable majority. Since Monarch George V is unwilling to work with a minority or caretaker FLP government, his preferred premier is Heinrich Brüning of the PPS Party, who could lead a "monarchial" government.

- @toleration_bruning: We will tolerate Brüning.
- @new_grand_coalition: We will try to form a new grand coalition.
- @new_elections: We will have new elections.

# - if SCP is the largest party and the 

@no_majority_bruning
go-to: no_majority_bruning_toleration if (no_majority_elections <= 3 and anti_democratic_coalition <= 50); georgev_appoints_papen if no_majority_elections > 3 or anti_democratic_coalition > 50


@georgev_appoints_papen
on-arrival: premier = "Papen"; premier_party = "I"; next_election_time = time+3; next_parl_election_month = month + 3; next_parl_election_year = year; next_parl_election_year += 1 if next_parl_election_month > 12; next_parl_election_month -= 12 if next_parl_election_month > 12; ful_banned = 0; pro_republic -= 8; finance_minister_party = "I"; interior_minister_party = "I"; economic_minister_party = "I"; labour_minister_party = "I"; foreign_minister_party = "I"; agriculture_minister_party = "I"; rcmp_minister = "I";

There is no path to a majority government. Monarch George V is tired of the chaos, and appoints Franz von Papen as premier instead of Brüning. Papen is a indenpendent formerly from the PPS Party, and is significantly to the right of the majority of the PPS Party.

Papen is immediately faced with a vote of no confidence, given his unpopularity. However the FLP votes, he is guaranteed to fall, due to the unanimous hatred against him from all other parties.

New elections have been set for [+ next_parl_election_month : month +] [+ next_parl_election_year +].

@no_majority_bruning_toleration
on-arrival: no_majority_bruning_elections += 1

There is no path to a majority government. One option would be to have a continuation of the current Brüning government; if we tolerate it, then it would retain a majority vote against no-confidence.

Alternatively, we could try to form a "new grand coalition" of all constitutional parties except the SCP, CP, and SCP. The stumbling block are the minor conservative parties such as the "Economic Party of the Middle Class", who detest any hint of socialism and would ruin the country before working with Marxists.

The third option is to have new elections.

- @toleration_bruning: We will tolerate Brüning.
- @new_grand_coalition: We will try to form a new grand coalition.
- @new_elections: We will have new elections.
- @unity_government


@new_grand_coalition
title: A "New Grand Coalition" of all the constitutional parties?
subtitle: FLP + PPS + [+ lps_name +] + CPS + Others ([+ neo_weimar_coalition +]%)
view-if: neo_weimar_coalition >= 50 and grand_coalition < 50
choose-if: pps_relation >= 50 and cps_relation >= 30
unavailable-subtitle: FLP + PPS + [+ lps_name +] + CPS + Others ([+ neo_weimar_coalition +]%) - [? if pps_relation < 50 : We do not have adequate relations with the PPS Party. ?][? if cps_relation < 30 : We do not have adequate relations with the CPS. ?]

How do we convince vehemently anti-socialist parties to allow us to form a majority coalition? Our largely benevolent relations with the PPS and CPS may allow us some leverage.

- @use_resources
- @toleration_bruning: No. We will tolerate a minority government.
- @new_elections: No. We will have new elections.
- @unity_government

@use_resources
title: Use our resources to smooth over the creation of a coalition.
subtitle: -2 resources
unavailable-subtitle: Not enough resources (need 2).
choose-if: resources >= 2
on-arrival: resources -= 2; flp_in_government = 1; in_grand_coalition = 1; left_dissent += 4;
achievement: constitutional_coalition

We transfer some of our campaign funds to our putative coalition partners. Some would call this corruption, but perhaps it is necessary to save our democracy.

Now, we have a new grand coalition, a "Constitutional Coalition" of all the non-fascist and non-communist parties. Leftists in our party are somewhat skeptical of this arrangement. 


Who should be premier?

- @join_bruning: For better or for worse, it must be Heinrich Brüning of the PPS.
- @woodsworth_premier_new: J. S. Woodsworth for Premier?

@woodsworth_premier_new
subtitle: This will reduce our leverage in the ministries.
view-if: not historical_mode or not flp_prussia
on-arrival: leverage -= 10; premier = "J. S. Woodsworth"; premier_party = "FLP"
go-to: ministries

We have assembled a new coalition under J. S. Woodsworth.


@unity_government
title: The PPS Party offers a "Government of National Unity" under Premier Joseph Wirth.
subtitle: FLP + PPS + [+ lps_name +] + CPS + Others ([+ neo_weimar_coalition +]%)
view-if: pps_party_leader == "Joos" and neo_weimar_coalition >= 50 and weimar_coalition < 50 and pps_relation >= 10

The PPS Party leader, Joseph Joos, clearly sees the threat from the ascension of the anti-democratic extremist parties, and thus tries to negotiate a "Government of National Unity" to save the republic. This coalition would be led by Joseph Wirth, a left-leaning member of the PPS Party and former premier, and would encompass all of the constitutional parties. Our role in this government might be limited, however.

- @unity_government_2
- @reject_unity_government: No, we will not accept this offer.

@unity_government_2
title: Accept the offer!
on-arrival: premier = "Wirth"; premier_party = "PPS"; flp_in_government = 1; in_grand_coalition = 1; in_unity_government = 1; leverage = 15; pps_relation += 5; cps_relation += 4
achievement: constitutional_coalition
go-to: ministries

We have formed a new unity government of all the constitutional parties! We have a limited choice in ministries for this government.


@reject_unity_government
on-arrival: pps_relation -= 8; lps_relation -= 5; cps_relation -= 5

Our rejection of the unity government has hurt our relations with the bourgeois and center-right parties.

- @woodsworths_dilemma
- @toleration_bruning: We will tolerate a minority government led by Brüning.
- @toleration_wirth: We will tolerate a minority government led by Joseph Wirth.
- @new_elections: There will be new elections.


@toleration_wirth
view-if: pps_party_leader = "Joos"
choose-if: monarch == "J. S. Woodsworth"
unavailable-subtitle: Monarch George V will not support a minority government led by Joseph Wirth.
on-arrival: premier = "Wirth"; premier_party = "PPS"; flp_in_government = 0; flp_toleration = 1; pps_relation += 5; foreign_minister_party = "CPS"; interior_minister_party = "PPS"; justice_minister_party = "I"; labour_minister_party = "PPS"; rcmp_minister_party = "I"; economic_minister_party = lps_name; finance_minister_party = "CPS"; agriculture_minister_party = "PPS"; pro_republic -= 2;

We have supported a minority government led by the PPS Party under Premier Joseph Wirth.



@no_majority_papen
on-arrival: pro_republic -= 10; next_election_time = time+3; next_parl_election_month = month + 3; next_parl_election_year = year; next_parl_election_year += 1 if next_parl_election_month > 12; next_parl_election_month -= 12 if next_parl_election_month > 12; no_majority_papen_elections += 1; workers_flp -= 8 if pro_republic < 45; workers_flp *= 0.85 if pro_republic < 40;

After the elections, Papen is still deeply unpopular, without any hint of coalition support, and there is a vote of no confidence called against him almost immediately. No matter how we vote, the measure would pass. The Assembly is dissolved once more.

New elections have been set for [+ next_parl_election_month : month +] [+ next_parl_election_year +].


@no_majority_papen_2
on-arrival: premier = "Schleicher"; pro_republic -= 10; next_election_time = time+5; next_parl_election_month = month + 5; next_parl_election_year = year; next_parl_election_year += 1 if next_parl_election_month > 12; next_parl_election_month -= 12 if next_parl_election_month > 12; workers_flp -= 8 if pro_republic < 45; workers_flp *= 0.85 if pro_republic < 40; finance_minister_party = "I"; interior_minister_party = "I"; economic_minister_party = "I"; labour_minister_party = "I"; foreign_minister_party = "I"; agriculture_minister_party = "I"; rcmp_minister = "I";

There is no path to a majority government. George V is displeased with Papen, and calls on him to resign. Now, former army general Kurt von Schleicher has been appointed premier, again as part of a monarchial government.

Schleicher's government is deeply unpopular among all parties of the Assembly. Despite his support for a coalition with the SCP, the SCPs want power all to themselves, without Schleicher.

New elections have been set for [+ next_parl_election_month : month +] [+ next_parl_election_year +].

# TODO: there should be a second Schleicher option if the SCP isn't the strongest

# if SCP is largest party and George V is monarch, then George V appoints Needham premier.

@flp_majority
title: FLP majority alone
subtitle: FLP: [+ flp_r +]%
view-if: flp_r >= 50
on-arrival: premier = "Empty"; premier_party = "FLP"; flp_in_government = 1; in_flp_majority = 1; pro_republic += 5; foreign_minister_party = "FLP"; foreign_minister = "Williams"; interior_minister_party = "FLP"; interior_minister = "Brockelbank"; justice_minister_party = "FLP"; justice_minister = "Underhill"; labour_minister_party = "FLP"; labour_minister = "Carlyle"; rcmp_minister_party = "FLP"; rcmp_minister = "Leber"; economic_minister_party = "FLP"; economic_minister = "Schmidt"; finance_minister_party = "FLP"; finance_minister = "Nicholson"; agriculture_minister_party = "FLP"; agriculture_minister = "Wright"; rcmp_loyalty -= 0.05; 
achievement: majority_party

Finally, the FLP can govern alone! Our long campaign of electioneering has paid off. We do not need to worry about coalition government; anything is possible. 

Who should be premier?

- @woodsworth_majority_premier: J. S. Woodsworth for Premier.
- @williams_majority_premier: George Hara Williams for Premier.
- @douglas_majority_premier: Tommy Douglas for Premier.
- @coldwell_majority_premier: Major James Coldwell for Premier.

@woodsworth_majority_premier
view-if: not historical_mode or not flp_prussia
on-arrival: premier = "J. S. Woodsworth"

[? if monarch == "J. S. Woodsworth": Our experts have checked the constitution, and have discovered that there is no specific prohibition against the Premier also being the Monarch (the Monarch may not be a member of the Assembly; there is no law saying that the Premier must be a member of the Assembly). Thus, we have Premier-Monarch J. S. Woodsworth. ?]
[? if monarch != "J. S. Woodsworth": J. S. Woodsworth has become premier of the FLP majority. ?]

@williams_majority_premier
on-arrival: premier = "Williams"

George Hara Williams has become premier of the FLP majority.

@douglas_majority_premier
view-if: douglas_dead = 0
on-arrival: premier = "Douglas"

Tommy Douglas has become premier of the FLP majority.

@coldwell_majority_premier
view-if: douglas_dead = 1
